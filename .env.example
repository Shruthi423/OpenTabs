# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# Get a bot token from @BotFather on Telegram.
# Get your chat/channel ID by adding the bot to the channel and checking
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Optional: funding alerts go to a SEPARATE channel.
# Set the CHAT_ID to turn funding on. Leave the BOT_TOKEN blank to reuse the
# bot above (add it to the funding channel), or give funding its own bot token.
TELEGRAM_FUNDING_CHAT_ID=
TELEGRAM_FUNDING_BOT_TOKEN=
